# ──────────────────────────────────────────────────────────────
# Database
# Use host.docker.internal when running inside Docker so the
# container can reach the host's Postgres instance.
# Use localhost when running the service directly on the host.
# ──────────────────────────────────────────────────────────────
DB_HOST=host.docker.internal
# DB_HOST=localhost   # uncomment when running outside Docker
DB_PORT=5433
DB_NAME=rkp_core
DB_USER=rkp_user
DB_PASSWORD=rkp_password

# ──────────────────────────────────────────────────────────────
# Anthropic (for summarization)
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────
# GitHub (for repo search / metadata)
# ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ──────────────────────────────────────────────────────────────
# Service
# ──────────────────────────────────────────────────────────────
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=info
